# API Configuration
API_URL=http://localhost:8080
NEXT_PUBLIC_IMAGE_URL=http://localhost:8080
API_TIMEOUT=10000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000

# Auth.js / NextAuth (must match backend AUTH_SECRET)
AUTH_SECRET=your-auth-secret-min-32-chars-long
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_GITHUB_ID=your-github-oauth-client-id
AUTH_GITHUB_SECRET=your-github-oauth-client-secret

# App Configuration
NEXT_PUBLIC_APP_NAME=STV CMS
NEXT_PUBLIC_APP_VERSION=0.2.0
NEXT_PUBLIC_DEFAULT_THEME=dark

# Feature Flags
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_ENABLE_QUERY_CACHING=true

# Debug (set to 'true' to enable debug logging)
# DEBUG=true
